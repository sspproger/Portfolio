---
import type { Project } from '../../data/projects';
import Card from '../ui/Card.astro';
import Button from '../ui/Button.astro';

const { project } = Astro.props as {
  project: Project;
};
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <div class="grid gap-6 lg:grid-cols-3">
    <Card>
      <p class="text-sm font-semibold text-blue-600">
        Задача
      </p>

      <p class="mt-4 leading-7 text-slate-600">
        {project.task}
      </p>
    </Card>

    <Card>
      <p class="text-sm font-semibold text-blue-600">
        Автоматизировано
      </p>

      <ul class="mt-4 space-y-2 text-sm text-slate-600">
        {project.automated.slice(0, 7).map((item) => (
          <li class="flex gap-2">
            <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-600"></span>
            <span>{item}</span>
          </li>
        ))}
      </ul>
    </Card>

    <Card>
      <p class="text-sm font-semibold text-blue-600">
        Результат
      </p>

      <p class="mt-4 leading-7 text-slate-600">
        {project.result}
      </p>

      <div class="mt-6 flex flex-col gap-3">
        <Button
          href={project.externalUrl}
          label="Открыть сайт"
          variant="secondary"
        />

        <Button
          href="/request"
          label="Обсудить похожий проект"
          variant="primary"
          goal="cta_process_review_click"
          goalLabel="case_summary"
        />
      </div>
    </Card>
  </div>
</section>