---
import type { Project } from '../../data/projects';
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const { project } = Astro.props as {
  project: Project;
};

const moduleDescriptions: Record<string, string> = {
  'публичная часть': 'Страницы, где участники получают информацию о конкурсе, конференции и условиях участия.',
  'форма заявки': 'Форма для сбора данных участников, организаций, направлений и другой информации.',
  'форма загрузки материалов': 'Интерфейс для отправки файлов, докладов, заявок или дополнительных материалов.',
  'база данных': 'Единое место хранения заявок, участников, статусов и связанных данных.',
  'файловое хранилище': 'Хранение загруженных файлов и связь файлов с конкретными заявками.',
  'административная панель': 'Интерфейс для оргкомитета: просмотр заявок, статусов, данных и файлов.',
  'статусы': 'Контроль этапов обработки: новая заявка, проверка, принято, требуется уточнение и другие состояния.',
  'документы': 'Подготовка приглашений, протоколов, справок или других документов по данным системы.',
  'рассылки': 'Отправка уведомлений участникам и ответственным сотрудникам.',
};
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <SectionHeader
    eyebrow="Модули"
    title="Что реализовано в системе"
    description="Кейс построен вокруг автоматизации полного цикла: от публичной формы до работы оргкомитета, документов и уведомлений."
  />

  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {project.modules.map((module) => (
      <Card>
        <h3 class="text-xl font-bold text-slate-900">
          {module}
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          {moduleDescriptions[module] ?? 'Модуль цифровой системы, который помогает автоматизировать отдельную часть процесса.'}
        </p>
      </Card>
    ))}
  </div>
</section>