---
import type { Project } from '../../data/projects';
import Button from '../ui/Button.astro';
import Tag from '../ui/Tag.astro';

const { project } = Astro.props as {
  project: Project;
};
---

<section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
  <a href="/projects" class="text-sm font-semibold text-blue-600 hover:text-blue-700">
    ← Все проекты
  </a>

  <div class="mt-8 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
    <div>
      <p class="text-sm font-semibold text-blue-600">
        {project.type}
      </p>

      <h1 class="mt-4 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        {project.title} — автоматизация конкурсов, конференции, заявок и рассылок
      </h1>

      <p class="mt-5 text-lg leading-8 text-slate-600">
        {project.description}
      </p>

      <div class="mt-6 flex flex-wrap gap-2">
        {project.tags.map((tag) => (
          <Tag label={tag} />
        ))}
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button
          href="/request"
          label="Хочу похожую систему"
          variant="primary"
          size="lg"
          goal="cta_process_review_click"
          goalLabel="case_hero"
        />

        <Button
          href={project.externalUrl}
          label="Открыть сайт"
          variant="secondary"
          size="lg"
        />
      </div>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-sm font-semibold text-slate-900">
        Важно
      </p>

      <p class="mt-4 leading-7 text-slate-600">
        Этот кейс показывает подход к автоматизации: формы, данные, файлы,
        статусы, документы, админ-панель и рассылки. Это один реализованный
        пример, а не единственное направление работы.
      </p>

      <a
        href="/services"
        class="mt-5 inline-flex font-semibold text-blue-600 hover:text-blue-700"
      >
        Смотреть направления автоматизации →
      </a>
    </div>
  </div>
</section>