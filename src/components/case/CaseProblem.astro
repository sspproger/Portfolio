---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const problems = [
  'заявки могут приходить из разных каналов и теряться в переписках',
  'файлы участников сложно проверять и связывать с конкретной заявкой',
  'оргкомитету нужно видеть статусы и быстро понимать состояние процесса',
  'документы и приглашения неудобно формировать вручную',
  'рассылки требуют времени и повторяющихся действий',
  'без единой системы процесс становится непрозрачным',
];
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <SectionHeader
    eyebrow="Проблема"
    title="Что обычно усложняет организацию конкурса или конференции"
    description="В подобных процессах часто много заявок, файлов, участников, документов и ручных уведомлений. Без единой системы это быстро превращается в набор таблиц, писем и ручных действий."
  />

  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {problems.map((problem) => (
      <Card>
        <p class="leading-7 text-slate-600">
          {problem}
        </p>
      </Card>
    ))}
  </div>
</section>