---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const results = [
  'единая точка приёма заявок',
  'структурированное хранение данных',
  'удобнее работа с файлами участников',
  'управление статусами обработки',
  'снижение ручной работы с документами',
  'возможность рассылок и уведомлений',
  'более прозрачная работа оргкомитета',
];
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <SectionHeader
    eyebrow="Результат"
    title="Что даёт такая цифровая система"
    description="Главный результат — процесс становится более управляемым: данные, файлы, статусы, документы и уведомления находятся в единой логике."
  />

  <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {results.map((result) => (
      <Card>
        <div class="flex gap-3">
          <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-green-600"></span>
          <p class="font-medium leading-7 text-slate-700">
            {result}
          </p>
        </div>
      </Card>
    ))}
  </div>
</section>