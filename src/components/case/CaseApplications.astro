---
import SectionHeader from '../ui/SectionHeader.astro';
import Button from '../ui/Button.astro';

const applications = [
  'конкурс',
  'конференция',
  'олимпиада',
  'образовательный проект',
  'грантовый отбор',
  'приём заявок на мероприятие',
  'внутренняя система заявок',
  'документооборот',
  'сервис для оргкомитета',
  'личный кабинет участников',
];
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
    <SectionHeader
      eyebrow="Где ещё применимо"
      title="Такой подход подходит не только для конкурса"
      description="Если в процессе есть заявки, участники, файлы, документы, статусы и уведомления — его можно разобрать и перевести в цифровую систему."
    />

    <div class="mt-8 grid gap-3 md:grid-cols-2 lg:grid-cols-3">
      {applications.map((item) => (
        <div class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
          {item}
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-2xl bg-blue-50 p-6">
      <p class="text-lg font-semibold text-slate-900">
        Если у вас похожий процесс — его можно разобрать и автоматизировать.
      </p>

      <div class="mt-5">
        <Button
          href="/request"
          label="Получить разбор процесса"
          variant="primary"
          size="lg"
          goal="cta_process_review_click"
          goalLabel="case_applications"
        />
      </div>
    </div>
  </div>
</section>