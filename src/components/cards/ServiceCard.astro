---
import type { Service } from '../../data/services';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';

const { service } = Astro.props as {
  service: Service;
};
---

<Card className="flex h-full flex-col">
  <div class="flex items-center justify-between gap-3">
    <Tag label={service.category} />
    <span class="text-xs font-semibold text-slate-500">
      {service.term}
    </span>
  </div>

  <h3 class="mt-5 text-2xl font-bold tracking-tight text-slate-900">
    {service.title}
  </h3>

  <p class="mt-3 text-base font-medium text-slate-700">
    {service.subtitle}
  </p>

  <p class="mt-4 text-sm leading-6 text-slate-600">
    {service.description}
  </p>

  <div class="mt-5">
    <p class="text-sm font-semibold text-slate-900">
      Что обычно входит:
    </p>

    <ul class="mt-3 space-y-2 text-sm text-slate-600">
      {service.modules.slice(0, 4).map((module) => (
        <li class="flex gap-2">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-600"></span>
          <span>{module}</span>
        </li>
      ))}
    </ul>
  </div>

  <div class="mt-auto pt-6">
    <div class="mb-5 flex items-center justify-between gap-4 border-t border-slate-200 pt-5">
      <span class="text-sm text-slate-500">Стоимость</span>
      <span class="font-semibold text-slate-900">{service.priceFrom}</span>
    </div>

    <Button
      href={`/services/${service.slug}`}
      label={service.cta}
      variant="secondary"
      size="md"
      goal="service_to_request_click"
      goalLabel={service.slug}
    />
  </div>
</Card>