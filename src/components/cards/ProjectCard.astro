---
import type { Project } from '../../data/projects';
import Card from '../ui/Card.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';

const { project } = Astro.props as {
  project: Project;
};
---

<Card className="grid gap-6 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
  <div>
    <p class="text-sm font-semibold text-blue-600">
      {project.type}
    </p>

    <h3 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">
      {project.title}
    </h3>

    <p class="mt-4 text-base leading-7 text-slate-600">
      {project.description}
    </p>

    <p class="mt-5 text-sm font-semibold text-slate-900">
      Результат:
    </p>

    <p class="mt-2 text-sm leading-6 text-slate-600">
      {project.result}
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      {project.tags.map((tag) => (
        <Tag label={tag} />
      ))}
    </div>

    <div class="mt-7 flex flex-col gap-3 sm:flex-row">
      <Button href={project.url} label={project.cta} variant="primary" />

      {project.externalUrl && (
        <Button
          href={project.externalUrl}
          label="Открыть сайт"
          variant="secondary"
          goal="external_case_open"
          goalLabel={project.slug}
        />
      )}
    </div>
  </div>

  <div class="rounded-3xl border border-slate-200 bg-slate-50 p-5">
    <p class="text-sm font-semibold text-slate-900">
      Что автоматизировано
    </p>

    <ul class="mt-4 grid gap-3 text-sm text-slate-600">
      {project.automated.slice(0, 8).map((item) => (
        <li class="flex gap-2">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-blue-600"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</Card>