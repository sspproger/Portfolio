---
const {
  eyebrow,
  title,
  description,
  align = 'left',
} = Astro.props as {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
};

const alignClasses = align === 'center' ? 'mx-auto text-center' : '';
---

<div class={`max-w-3xl ${alignClasses}`}>
  {eyebrow && (
    <p class="text-sm font-semibold text-blue-600">
      {eyebrow}
    </p>
  )}

  <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
    {title}
  </h2>

  {description && (
    <p class="mt-4 text-lg leading-8 text-slate-600">
      {description}
    </p>
  )}
</div>