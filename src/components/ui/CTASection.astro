---
import { contacts } from '../../data/contacts';
import Button from './Button.astro';

const {
  title,
  description,
  primaryLabel = 'Получить бесплатный разбор процесса',
  primaryHref = '/request',
  secondaryLabel = 'Посмотреть проекты',
  secondaryHref = '/projects',
} = Astro.props as {
  title: string;
  description: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
};
---

<section class="rounded-3xl border border-blue-100 bg-blue-50 p-8 md:p-10">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
      {title}
    </h2>

    <p class="mt-4 text-lg leading-8 text-slate-600">
      {description}
    </p>

    <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
      <Button
        href={primaryHref}
        label={primaryLabel}
        variant="primary"
        size="lg"
        goal="cta_process_review_click"
        goalLabel="cta_section"
      />

      <Button
        href={secondaryHref}
        label={secondaryLabel}
        variant="secondary"
        size="lg"
      />
    </div>

    <p class="mt-6 text-sm text-slate-600">
      Или свяжитесь напрямую:
      <a
        href={contacts.phoneHref}
        data-goal="phone_click"
        data-goal-label="cta_section"
        class="font-semibold text-blue-600 hover:text-blue-700"
      >
        {contacts.phone}
      </a>
    </p>
  </div>
</section>