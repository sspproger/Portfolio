---
type Variant = 'primary' | 'secondary' | 'ghost';
type Size = 'sm' | 'md' | 'lg';

const {
  href,
  variant = 'primary',
  size = 'md',
  label,
  goal,
  goalLabel,
  type = 'button',
} = Astro.props as {
  href?: string;
  variant?: Variant;
  size?: Size;
  label: string;
  goal?: string;
  goalLabel?: string;
  type?: 'button' | 'submit';
};

const baseClasses =
  'inline-flex items-center justify-center rounded-xl font-semibold transition focus:outline-none focus:ring-2 focus:ring-blue-600 focus:ring-offset-2';

const variantClasses: Record<Variant, string> = {
  primary: 'bg-blue-600 text-white hover:bg-blue-700',
  secondary: 'border border-slate-300 bg-white text-slate-900 hover:bg-slate-50',
  ghost: 'text-slate-700 hover:bg-slate-100',
};

const sizeClasses: Record<Size, string> = {
  sm: 'px-3 py-2 text-sm',
  md: 'px-5 py-3 text-sm',
  lg: 'px-6 py-4 text-base',
};

function getAutoGoal(href?: string) {
  if (!href) return undefined;
  if (href === '/request') return 'cta_process_review_click';
  if (href === '/demo') return 'demo_view';
  if (href === '/projects/konkursbstu') return 'project_case_click';
  if (href.startsWith('tel:')) return 'phone_click';
  if (href.includes('konkursbstu.ru')) return 'external_case_open';
  if (href.endsWith('.pdf')) return 'pdf_case_download';
  return undefined;
}

const computedGoal = goal || getAutoGoal(href);
const computedGoalLabel = goalLabel || href || '';
const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]}`;
---

{href ? (
  <a
    href={href}
    class={classes}
    data-goal={computedGoal}
    data-goal-label={computedGoalLabel}
  >
    {label}
  </a>
) : (
  <button
    type={type}
    class={classes}
    data-goal={computedGoal}
    data-goal-label={computedGoalLabel}
  >
    {label}
  </button>
)}