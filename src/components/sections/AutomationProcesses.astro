---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const processes = [
  {
    title: 'Заявки',
    description: 'Приём, хранение, обработка, статусы и уведомления по заявкам.',
  },
  {
    title: 'Документы',
    description: 'Шаблоны, генерация PDF/DOCX, хранение и выдача документов.',
  },
  {
    title: 'Файлы',
    description: 'Загрузка, проверка, хранение и связь файлов с заявками.',
  },
  {
    title: 'Статусы',
    description: 'Контроль этапов обработки, ответственных и текущего состояния.',
  },
  {
    title: 'Рассылки',
    description: 'Email, Telegram и другие уведомления по событиям процесса.',
  },
  {
    title: 'Админ-панели',
    description: 'Управление заявками, пользователями, файлами и документами.',
  },
  {
    title: 'Личные кабинеты',
    description: 'Интерфейсы для участников, клиентов, сотрудников или партнёров.',
  },
  {
    title: 'Отчётность',
    description: 'Сводки, фильтры, выгрузки и контроль ключевых показателей.',
  },
  {
    title: 'Excel-процессы',
    description: 'Перенос таблиц, ручного копирования и файлов в веб-систему.',
  },
  {
    title: 'Workflow',
    description: 'Маршруты, роли, этапы, согласования и журнал действий.',
  },
  {
    title: 'Внутренние сервисы',
    description: 'Инструменты для сотрудников, отделов и административных задач.',
  },
  {
    title: 'Интеграции',
    description: 'Связь системы с внешними сервисами, почтой, Telegram или CRM.',
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <SectionHeader
    eyebrow="Что можно автоматизировать"
    title="Любой повторяющийся процесс можно превратить в цифровую систему"
    description="Если процесс можно описать, разбить на этапы и перевести в правила — его можно автоматизировать: от простой формы до системы с ролями, документами и уведомлениями."
  />

  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {processes.map((process) => (
      <Card>
        <h3 class="text-xl font-bold text-slate-900">
          {process.title}
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          {process.description}
        </p>
      </Card>
    ))}
  </div>
</section>