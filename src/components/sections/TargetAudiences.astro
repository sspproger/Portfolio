---
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';

const audiences = [
  {
    title: 'Малый и средний бизнес',
    description:
      'Автоматизация заявок, внутренних сервисов, документов, рассылок, таблиц и отчётности.',
  },
  {
    title: 'Университеты, кафедры, факультеты',
    description:
      'Системы для мероприятий, заявок, участников, документов, материалов и оргкомитетов.',
  },
  {
    title: 'Оргкомитеты конкурсов и конференций',
    description:
      'Порталы для приёма заявок, файлов, статусов, приглашений, документов и рассылок.',
  },
  {
    title: 'Образовательные проекты',
    description:
      'Личные кабинеты, формы участия, базы данных, статусы, уведомления и материалы.',
  },
  {
    title: 'Сервисные компании',
    description:
      'Заявки клиентов, статусы выполнения, уведомления, документы и внутренние панели.',
  },
  {
    title: 'Производственные и административные подразделения',
    description:
      'Внутренние workflow-системы, учёт, документы, согласования, файлы и отчёты.',
  },
  {
    title: 'Проекты с большим количеством заявок',
    description:
      'Сбор данных, обработка, проверка, хранение, статусы и уведомления в одной системе.',
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <SectionHeader
    eyebrow="Для кого"
    title="Для организаций, где процессы уже стали слишком ручными"
    description="Система особенно полезна там, где много заявок, документов, файлов, статусов, участников, сотрудников и повторяющихся операций."
  />

  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {audiences.map((audience) => (
      <Card>
        <h3 class="text-xl font-bold text-slate-900">
          {audience.title}
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          {audience.description}
        </p>
      </Card>
    ))}
  </div>
</section>