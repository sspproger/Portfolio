---
import Button from '../ui/Button.astro';

const demoItems = [
  'форма',
  'заявка',
  'админ-панель',
  'статусы',
  'документы',
  'уведомления',
];
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <div class="rounded-3xl border border-slate-200 bg-white p-8 shadow-sm md:p-10">
    <div class="grid gap-10 lg:grid-cols-[1fr_0.8fr] lg:items-center">
      <div>
        <p class="text-sm font-semibold text-blue-600">
          Демо
        </p>

        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          Можно посмотреть логику похожей системы
        </h2>

        <p class="mt-4 text-lg leading-8 text-slate-600">
          Демо помогает понять, как может выглядеть цифровая система:
          от формы и заявки до админ-панели, статусов, документов и уведомлений.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <Button href="/demo" label="Посмотреть демо" variant="primary" size="lg" />
          <Button
            href="/request"
            label="Запросить похожую систему"
            variant="secondary"
            size="lg"
            goal="cta_process_review_click"
            goalLabel="home_demo"
          />
        </div>
      </div>

      <div class="grid gap-3 sm:grid-cols-2">
        {demoItems.map((item) => (
          <div class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
            {item}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>