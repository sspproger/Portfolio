---
import { faq } from '../../data/faq';
import SectionHeader from '../ui/SectionHeader.astro';

const visibleFaq = faq.slice(0, 8);
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <SectionHeader
    eyebrow="FAQ"
    title="Частые вопросы"
    description="Короткие ответы на вопросы, которые обычно возникают перед разработкой цифровой системы."
  />

  <div class="mt-10 grid gap-4">
    {visibleFaq.map((item) => (
      <details class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <summary class="cursor-pointer font-semibold text-slate-900">
          {item.question}
        </summary>

        <p class="mt-4 leading-7 text-slate-600">
          {item.answer}
        </p>
      </details>
    ))}
  </div>
</section>