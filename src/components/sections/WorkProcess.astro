---
import { processSteps } from '../../data/process';
import SectionHeader from '../ui/SectionHeader.astro';
import Card from '../ui/Card.astro';
---

<section class="mx-auto max-w-6xl px-4 py-16">
  <SectionHeader
    eyebrow="Как проходит работа"
    title="От разбора процесса до запуска MVP"
    description="Работа начинается не с кода, а с понимания процесса: какие действия повторяются, какие данные используются и что можно упростить первым."
  />

  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {processSteps.map((step, index) => (
      <Card>
        <div class="flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
          {index + 1}
        </div>

        <h3 class="mt-5 text-xl font-bold text-slate-900">
          {step.title}
        </h3>

        <p class="mt-3 text-sm leading-6 text-slate-600">
          {step.description}
        </p>

        <p class="mt-4 text-sm font-semibold text-slate-900">
          Результат: {step.result}
        </p>
      </Card>
    ))}
  </div>
</section>