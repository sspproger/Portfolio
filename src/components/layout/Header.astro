---
import { navigation, mainCta } from '../../data/navigation';
import { contacts } from '../../data/contacts';

const currentPath = Astro.url.pathname;

function isActive(href: string) {
  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath === href || currentPath.startsWith(`${href}/`);
}
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex items-center justify-between gap-4 py-4">
      <a
        href="/"
        class="min-w-0 text-sm font-bold text-slate-900 sm:text-base"
        aria-label="На главную"
      >
        Автоматизация процессов
      </a>

      <nav class="hidden items-center gap-5 lg:flex" aria-label="Основная навигация">
        {navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'text-sm font-medium transition',
              isActive(item.href)
                ? 'text-blue-600'
                : 'text-slate-600 hover:text-slate-900',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-3 sm:flex">
        <a
          href={contacts.phoneHref}
          data-goal="phone_click"
          data-goal-label="header"
          class="hidden text-sm font-semibold text-slate-700 hover:text-blue-600 xl:inline"
        >
          {contacts.phone}
        </a>

        <a
          href={mainCta.href}
          data-goal="cta_process_review_click"
          data-goal-label="header"
          class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700"
        >
          {mainCta.label}
        </a>
      </div>

      <button
        type="button"
        data-mobile-menu-button
        aria-controls="mobile-menu"
        aria-expanded="false"
        class="inline-flex items-center justify-center rounded-xl border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-900 hover:bg-slate-50 lg:hidden"
      >
        Меню
      </button>
    </div>

    <div
      id="mobile-menu"
      data-mobile-menu
      hidden
      class="border-t border-slate-200 py-4 lg:hidden"
    >
      <nav class="grid gap-2" aria-label="Мобильная навигация">
        {navigation.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-xl px-3 py-3 text-sm font-medium transition',
              isActive(item.href)
                ? 'bg-blue-50 text-blue-600'
                : 'text-slate-700 hover:bg-slate-50',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="mt-4 grid gap-3 border-t border-slate-200 pt-4">
        <a
          href={contacts.phoneHref}
          data-goal="phone_click"
          data-goal-label="mobile_header"
          class="rounded-xl border border-slate-300 bg-white px-4 py-3 text-center text-sm font-semibold text-slate-900 hover:bg-slate-50"
        >
          {contacts.phone}
        </a>

        <a
          href={mainCta.href}
          data-goal="cta_process_review_click"
          data-goal-label="mobile_header"
          class="rounded-xl bg-blue-600 px-4 py-3 text-center text-sm font-semibold text-white hover:bg-blue-700"
        >
          Получить разбор процесса
        </a>
      </div>
    </div>
  </div>

  <script is:inline>
    const menuButton = document.querySelector('[data-mobile-menu-button]');
    const mobileMenu = document.querySelector('[data-mobile-menu]');

    if (menuButton && mobileMenu) {
      menuButton.addEventListener('click', () => {
        const isOpen = menuButton.getAttribute('aria-expanded') === 'true';

        menuButton.setAttribute('aria-expanded', String(!isOpen));
        mobileMenu.hidden = isOpen;
      });
    }
  </script>
</header>