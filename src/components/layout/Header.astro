---
import { navigation, mainCta } from '../../data/navigation';
import { contacts } from '../../data/contacts';
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="font-bold text-slate-900">
      Автоматизация процессов
    </a>

    <nav class="hidden items-center gap-5 md:flex">
      {navigation.map((item) => (
        <a href={item.href} class="text-sm font-medium text-slate-600 hover:text-slate-900">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={contacts.phoneHref}
        data-goal="phone_click"
        class="hidden text-sm font-semibold text-slate-700 hover:text-blue-600 sm:inline"
      >
        {contacts.phone}
      </a>

      <a
        href={mainCta.href}
        data-goal="cta_process_review_click"
        data-goal-label="header"
        class="rounded-xl bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700"
      >
        {mainCta.label}
      </a>
    </div>
  </div>
</header>