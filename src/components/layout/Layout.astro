---
import '../../styles/global.css';

import Header from './Header.astro';
import Footer from './Footer.astro';
import YandexMetrika from '../analytics/YandexMetrika.astro';

import { metrikaConfig } from '../../data/analytics';

const {
  title = 'Автоматизация процессов и цифровые системы',
  description = 'Разработка цифровых систем для автоматизации заявок, документов, файлов, статусов, админ-панелей, личных кабинетов, рассылок и workflow-решений.',
  ogImage = '/og-image.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    <link rel="icon" href="/favicon.svg" />

    {metrikaConfig.enabled && <YandexMetrika id={metrikaConfig.id} />}
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />
    <slot />
    <Footer />

    <script is:inline src="/scripts/analytics.js"></script>
    <script is:inline src="/scripts/forms.js"></script>
  </body>
</html>