---
import '../../styles/global.css';

import Header from './Header.astro';
import Footer from './Footer.astro';
import YandexMetrika from '../analytics/YandexMetrika.astro';
import StructuredData from '../seo/StructuredData.astro';

import { metrikaConfig } from '../../data/analytics';
import { site } from '../../data/site';
import { getCanonicalUrl, joinUrl } from '../../utils/seo';

const {
  title = site.name,
  description = site.description,
  canonicalPath = Astro.url.pathname,
  ogImage = site.ogImage,
  noindex = false,
  schema,
} = Astro.props as {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
};

const canonicalUrl = getCanonicalUrl(site.url, canonicalPath);
const absoluteOgImage = joinUrl(site.url, ogImage);
const robotsContent = noindex ? 'noindex,nofollow' : 'index,follow';
const apiBaseUrl = site.apiBaseUrl;
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="robots" content={robotsContent} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <meta name="theme-color" content="#2563EB" />

    {site.yandexVerification && (
      <meta name="yandex-verification" content={site.yandexVerification} />
    )}

    <link rel="icon" href={site.favicon} />
    <link rel="manifest" href="/site.webmanifest" />

    <script is:inline define:vars={{ apiBaseUrl }}>
      window.__PUBLIC_API_BASE_URL__ = apiBaseUrl;
    </script>

    <StructuredData schema={schema} />

    {metrikaConfig.enabled && <YandexMetrika id={metrikaConfig.id} />}
  </head>

  <body class="bg-slate-50 text-slate-900">
    <Header />
    <slot />
    <Footer />

    <script is:inline src="/scripts/analytics.js"></script>
    <script is:inline src="/scripts/forms.js"></script>
  </body>
</html>