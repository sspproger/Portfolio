---
import { navigation } from '../../data/navigation';
import { contacts } from '../../data/contacts';

const year = new Date().getFullYear();

const importantLinks = [
  { label: 'Оставить заявку', href: '/request' },
  { label: 'Услуги', href: '/services' },
  { label: 'Кейс konkursbstu.ru', href: '/projects/konkursbstu' },
  { label: 'Контакты', href: '/contacts' },
];
---

<footer class="border-t border-slate-200 bg-white">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 md:grid-cols-3">
    <div>
      <p class="font-bold text-slate-900">
        Автоматизация процессов и цифровые системы
      </p>

      <p class="mt-3 text-sm leading-6 text-slate-600">
        Заявки, документы, файлы, статусы, админ-панели, личные кабинеты,
        рассылки, отчётность и workflow-решения.
      </p>

      <div class="mt-5 grid gap-2">
        {importantLinks.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-blue-600 hover:text-blue-700"
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <div>
      <p class="font-semibold text-slate-900">Навигация</p>

      <nav class="mt-3 flex flex-col gap-2" aria-label="Навигация в подвале">
        {navigation.map((item) => (
          <a href={item.href} class="text-sm text-slate-600 hover:text-slate-900">
            {item.label}
          </a>
        ))}
      </nav>
    </div>

    <div>
      <p class="font-semibold text-slate-900">Контакты</p>

      <div class="mt-3 text-sm leading-6 text-slate-600">
        <p>{contacts.degree}</p>
        <p>{contacts.position}</p>
        <p>{contacts.organization}</p>
        <p class="font-semibold text-slate-900">{contacts.name}</p>

        <a
          href={contacts.phoneHref}
          data-goal="phone_click"
          data-goal-label="footer"
          class="mt-2 inline-flex font-semibold text-blue-600 hover:text-blue-700"
        >
          {contacts.phone}
        </a>
      </div>

      <p class="mt-6 text-xs text-slate-500">
        © {year}. Автоматизация процессов и цифровые системы.
      </p>
    </div>
  </div>
</footer>