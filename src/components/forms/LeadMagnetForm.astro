---
import { contacts } from '../../data/contacts';

const {
  title,
  description,
  buttonLabel,
  leadMagnetSlug,
} = Astro.props as {
  title: string;
  description: string;
  buttonLabel: string;
  leadMagnetSlug: string;
};
---

<form
  data-form="demo"
  class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm"
>
  <input type="hidden" name="form_type" value="lead_magnet" />
  <input type="hidden" name="lead_magnet" value={leadMagnetSlug} />
  <input type="hidden" name="utm_source" />
  <input type="hidden" name="utm_medium" />
  <input type="hidden" name="utm_campaign" />
  <input type="hidden" name="utm_content" />
  <input type="hidden" name="utm_term" />

  <h2 class="text-2xl font-bold text-slate-900">
    {title}
  </h2>

  <p class="mt-3 text-sm leading-6 text-slate-600">
    {description}
  </p>

  <div class="mt-5">
    <label for={`lead-magnet-name-${leadMagnetSlug}`} class="text-sm font-semibold text-slate-900">
      Имя
    </label>
    <input
      id={`lead-magnet-name-${leadMagnetSlug}`}
      name="name"
      type="text"
      required
      class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-blue-600"
      placeholder="Ваше имя"
    />
  </div>

  <div class="mt-4">
    <label for={`lead-magnet-contact-${leadMagnetSlug}`} class="text-sm font-semibold text-slate-900">
      Телефон или email
    </label>
    <input
      id={`lead-magnet-contact-${leadMagnetSlug}`}
      name="contact"
      type="text"
      required
      class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-blue-600"
      placeholder="+7... или mail@example.ru"
    />
  </div>

  <button
    type="submit"
    class="mt-6 w-full rounded-xl bg-blue-600 px-6 py-3 font-semibold text-white hover:bg-blue-700"
  >
    {buttonLabel}
  </button>

  <p class="mt-4 text-sm leading-6 text-slate-500">
    Форма пока работает в демо-режиме. На следующем этапе будет подключена
    отправка в Telegram, email или CRM.
  </p>

  <div
    data-form-success
    hidden
    class="mt-5 rounded-2xl border border-green-200 bg-green-50 p-4 text-sm leading-6 text-slate-700"
  >
    Спасибо! Запрос зафиксирован в демо-режиме. Для быстрой связи можно
    позвонить по телефону
    <a href={contacts.phoneHref} class="font-semibold text-blue-600">
      {contacts.phone}
    </a>.
  </div>
</form>