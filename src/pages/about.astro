---
import Layout from '../components/layout/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import { contacts } from '../data/contacts';

const approach = [
  'сначала разбор процесса',
  'затем MVP',
  'затем интерфейсы и логика',
  'затем документы, уведомления и интеграции',
  'затем запуск и улучшения',
];

const difference = [
  'сайт показывает информацию',
  'цифровая система принимает данные',
  'хранит данные',
  'обрабатывает процесс',
  'помогает сотрудникам',
  'формирует документы',
  'отправляет уведомления',
];
---

<Layout
  title="О разработчике цифровых систем автоматизации"
  description="Информация о разработчике цифровых систем для автоматизации заявок, документов, файлов, админ-панелей, личных кабинетов и workflow."
>
  <main>
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold text-blue-600">
            О разработчике
          </p>

          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            О разработчике
          </h1>

          <p class="mt-5 text-lg leading-8 text-slate-600">
            Основной фокус — разработка цифровых систем для автоматизации
            формализуемых процессов: заявок, документов, файлов, статусов,
            админ-панелей, личных кабинетов, рассылок и workflow.
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <Button
              href="/request"
              label="Получить разбор процесса"
              variant="primary"
              size="lg"
            />

            <Button
              href="/projects/konkursbstu"
              label="Смотреть кейс"
              variant="secondary"
              size="lg"
            />
          </div>
        </div>

        <Card>
          <p class="text-xl font-bold text-slate-900">
            {contacts.name}
          </p>

          <p class="mt-3 text-slate-600">{contacts.degree}</p>
          <p class="text-slate-600">{contacts.position}</p>
          <p class="text-slate-600">{contacts.organization}</p>

          <a
            href={contacts.phoneHref}
            data-goal="phone_click"
            data-goal-label="about_page"
            class="mt-5 inline-flex text-lg font-semibold text-blue-600 hover:text-blue-700"
          >
            {contacts.phone}
          </a>
        </Card>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="grid gap-6 lg:grid-cols-2">
        <Card>
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">
            Подход к разработке
          </h2>

          <div class="mt-6 grid gap-3">
            {approach.map((item, index) => (
              <div class="flex gap-3 rounded-2xl bg-slate-50 p-4">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white">
                  {index + 1}
                </span>
                <p class="text-sm font-semibold text-slate-700">{item}</p>
              </div>
            ))}
          </div>
        </Card>

        <Card>
          <h2 class="text-3xl font-bold tracking-tight text-slate-900">
            Почему это не просто сайт
          </h2>

          <div class="mt-6 grid gap-3">
            {difference.map((item) => (
              <div class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
                {item}
              </div>
            ))}
          </div>
        </Card>
      </div>
    </section>

    <script is:inline>
      window.__pendingAnalyticsGoals = window.__pendingAnalyticsGoals || [];
      window.siteAnalytics?.reachGoal
        ? window.siteAnalytics.reachGoal('about_page_view', {
            page: window.location.pathname,
          })
        : window.__pendingAnalyticsGoals.push({
            goal: 'about_page_view',
            params: { page: window.location.pathname },
          });
    </script>
  </main>
</Layout>