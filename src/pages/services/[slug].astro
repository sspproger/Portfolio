---
import Layout from '../../components/layout/Layout.astro';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTASection from '../../components/ui/CTASection.astro';
import Tag from '../../components/ui/Tag.astro';

import { services } from '../../data/services';
import type { Service } from '../../data/services';
import { faq } from '../../data/faq';
import { getSEO } from '../../data/seo';
import {
  createBreadcrumbSchema,
  createServiceSchema,
} from '../../data/schema';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props as {
  service: Service;
};

const canonicalPath = `/services/${service.slug}`;
const pageSeo = getSEO(canonicalPath);

const serviceFaq = faq.slice(0, 6);

const applicationExamples = [
  'приём заявок',
  'обработка данных',
  'работа с файлами',
  'документы и шаблоны',
  'уведомления и рассылки',
  'административные панели',
  'личные кабинеты',
  'внутренние процессы организации',
];
---

<Layout
  title={pageSeo?.title || service.seo.title}
  description={pageSeo?.description || service.seo.description}
  canonicalPath={canonicalPath}
  schema={[
    createServiceSchema({
      name: service.title,
      description: service.description,
      url: canonicalPath,
    }),
    createBreadcrumbSchema([
      { name: 'Главная', url: '/' },
      { name: 'Услуги', url: '/services' },
      { name: service.title, url: canonicalPath },
    ]),
  ]}
>
  <main id="main-content">
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <a href="/services" class="text-sm font-semibold text-blue-600 hover:text-blue-700">
        ← Все услуги
      </a>

      <div class="mt-8 grid gap-10 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
        <div>
          <Tag label={service.category} />

          <h1 class="mt-5 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            {pageSeo?.h1 || service.seo.h1 || service.title}
          </h1>

          <p class="mt-5 text-xl font-medium leading-8 text-slate-700">
            {service.subtitle}
          </p>

          <p class="mt-5 text-lg leading-8 text-slate-600">
            {service.description}
          </p>

          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <Button
              href="/request"
              label="Получить разбор процесса"
              variant="primary"
              size="lg"
              goal="cta_process_review_click"
              goalLabel={service.slug}
            />

            <Button
              href="/projects/konkursbstu"
              label="Смотреть кейс"
              variant="secondary"
              size="lg"
              goal="project_case_click"
              goalLabel={service.slug}
            />
          </div>
        </div>

        <Card>
          <p class="text-sm font-semibold text-blue-600">
            Кратко
          </p>

          <div class="mt-5 grid gap-5">
            <div>
              <p class="text-sm text-slate-500">Срок</p>
              <p class="mt-1 font-semibold text-slate-900">{service.term}</p>
            </div>

            <div>
              <p class="text-sm text-slate-500">Стоимость</p>
              <p class="mt-1 font-semibold text-slate-900">{service.priceFrom}</p>
            </div>

            <div>
              <p class="text-sm text-slate-500">Первый шаг</p>
              <p class="mt-1 font-semibold text-slate-900">
                Разбор процесса и определение MVP
              </p>
            </div>
          </div>
        </Card>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="grid gap-6 lg:grid-cols-2">
        <Card>
          <h2 class="text-2xl font-bold text-slate-900">
            Какая проблема решается
          </h2>

          <p class="mt-4 leading-7 text-slate-600">
            {service.problem}
          </p>
        </Card>

        <Card>
          <h2 class="text-2xl font-bold text-slate-900">
            Какой результат получает организация
          </h2>

          <p class="mt-4 leading-7 text-slate-600">
            {service.result}
          </p>
        </Card>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <SectionHeader
        eyebrow="Состав решения"
        title="Что входит в решение"
        description="Состав системы зависит от процесса. Обычно MVP включает только те модули, которые сразу дают практическую пользу."
      />

      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {service.includes.map((item) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-5">
            <p class="font-semibold text-slate-900">{item}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <SectionHeader
        eyebrow="Модули"
        title="Какие модули можно реализовать"
        description="Модули подбираются под задачу: от простой формы до полноценной системы с ролями, статусами, файлами и документами."
      />

      <div class="mt-8 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {service.modules.map((module) => (
          <div class="flex gap-3 rounded-2xl bg-slate-50 p-5">
            <span class="mt-2 h-2 w-2 shrink-0 rounded-full bg-blue-600"></span>
            <p class="font-medium text-slate-700">{module}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="grid gap-6 lg:grid-cols-[0.8fr_1.2fr]">
        <Card>
          <h2 class="text-2xl font-bold text-slate-900">
            Сроки и стоимость
          </h2>

          <div class="mt-6 space-y-5">
            <div>
              <p class="text-sm text-slate-500">Ориентировочный срок</p>
              <p class="mt-1 text-xl font-bold text-slate-900">{service.term}</p>
            </div>

            <div>
              <p class="text-sm text-slate-500">Ориентировочная стоимость</p>
              <p class="mt-1 text-xl font-bold text-slate-900">{service.priceFrom}</p>
            </div>

            <p class="text-sm leading-6 text-slate-600">
              Точная оценка зависит от количества ролей, форм, документов,
              интеграций, уведомлений и сложности процесса.
            </p>
          </div>
        </Card>

        <Card>
          <h2 class="text-2xl font-bold text-slate-900">
            Где это применимо
          </h2>

          <div class="mt-6 grid gap-3 md:grid-cols-2">
            {applicationExamples.map((item) => (
              <div class="rounded-2xl bg-slate-50 p-4 text-sm font-medium text-slate-700">
                {item}
              </div>
            ))}
          </div>
        </Card>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl border border-blue-100 bg-blue-50 p-8 md:p-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold text-blue-600">
              Пример реализованного подхода
            </p>

            <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">
              Кейс konkursbstu.ru
            </h2>

            <p class="mt-4 text-lg leading-8 text-slate-600">
              Цифровая система для автоматизации конкурса и конференции:
              публичные формы, заявки, файлы, база данных, админ-панель,
              статусы, документы, приглашения и рассылки.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            <Button
              href="/projects/konkursbstu"
              label="Смотреть кейс"
              variant="primary"
              size="lg"
              goal="project_case_click"
              goalLabel={`service_${service.slug}_case_block`}
            />

            <Button
              href="/request"
              label="Хочу похожую систему"
              variant="secondary"
              size="lg"
              goal="cta_process_review_click"
              goalLabel={`service_${service.slug}_case_block`}
            />
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <SectionHeader
        eyebrow="FAQ"
        title="Частые вопросы"
        description="Короткие ответы на вопросы, которые обычно возникают перед автоматизацией процесса."
      />

      <div class="mt-8 grid gap-4">
        {serviceFaq.map((item) => (
          <details class="rounded-2xl border border-slate-200 bg-white p-5">
            <summary class="cursor-pointer font-semibold text-slate-900">
              {item.question}
            </summary>

            <p class="mt-4 leading-7 text-slate-600">
              {item.answer}
            </p>
          </details>
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title={service.cta}
        description="Опишите процесс простыми словами. На первом этапе достаточно рассказать, как он работает сейчас и что в нём неудобно."
        primaryLabel="Получить бесплатный разбор процесса"
        primaryHref="/request"
        secondaryLabel="Смотреть кейс"
        secondaryHref="/projects/konkursbstu"
      />
    </section>
  </main>
</Layout>