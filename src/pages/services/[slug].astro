---
import Layout from '../../components/layout/Layout.astro';
import CTASection from '../../components/ui/CTASection.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<Layout title={service.seo.title} description={service.seo.description}>
  <main class="mx-auto max-w-6xl px-4 py-16 md:py-20">
    <a href="/services" class="text-sm font-semibold text-blue-600 hover:text-blue-700">
      ← Все услуги
    </a>

    <p class="mt-8 text-sm font-semibold text-blue-600">
      {service.category}
    </p>

    <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
      {service.title}
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      {service.description}
    </p>

    <div class="mt-10 grid gap-6 lg:grid-cols-2">
      <div class="rounded-3xl border border-slate-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-slate-900">
          Проблема
        </h2>

        <p class="mt-4 leading-7 text-slate-600">
          {service.problem}
        </p>
      </div>

      <div class="rounded-3xl border border-slate-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-slate-900">
          Результат
        </h2>

        <p class="mt-4 leading-7 text-slate-600">
          {service.result}
        </p>
      </div>
    </div>

    <div class="mt-10 rounded-3xl border border-slate-200 bg-white p-6">
      <h2 class="text-2xl font-bold text-slate-900">
        Что может входить в систему
      </h2>

      <div class="mt-6 grid gap-3 md:grid-cols-2">
        {service.includes.map((item) => (
          <div class="rounded-2xl bg-slate-50 p-4 text-sm font-medium text-slate-700">
            {item}
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12">
      <CTASection
        title={service.cta}
        description="Опишите процесс, который хотите автоматизировать. На первом шаге достаточно рассказать, как всё работает сейчас."
        primaryLabel="Получить разбор процесса"
        primaryHref="/request"
        secondaryLabel="Смотреть кейс"
        secondaryHref="/projects/konkursbstu"
      />
    </div>
  </main>
</Layout>