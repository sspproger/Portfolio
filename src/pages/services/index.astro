---
import Layout from '../../components/layout/Layout.astro';
import ServiceCard from '../../components/cards/ServiceCard.astro';
import CTASection from '../../components/ui/CTASection.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Card from '../../components/ui/Card.astro';
import Button from '../../components/ui/Button.astro';

import { services } from '../../data/services';
import { getSEO } from '../../data/seo';
import {
  createBreadcrumbSchema,
  createServiceSchema,
} from '../../data/schema';

const pageSeo = getSEO('/services')!;
---

<Layout
  title={pageSeo.title}
  description={pageSeo.description}
  canonicalPath="/services"
  schema={[
    createServiceSchema(),
    createBreadcrumbSchema([
      { name: 'Главная', url: '/' },
      { name: 'Услуги', url: '/services' },
    ]),
  ]}
>
  <main>
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="text-sm font-semibold text-blue-600">
        Услуги
      </p>

      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Услуги по автоматизации процессов
      </h1>

      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
        Разработка цифровых систем для автоматизации заявок, документов,
        файлов, статусов, админ-панелей, личных кабинетов, рассылок,
        отчётности и workflow-процессов.
      </p>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="grid gap-6 md:grid-cols-2">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <Card>
        <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-center">
          <div>
            <h2 class="text-3xl font-bold tracking-tight text-slate-900">
              Не знаете, какая услуга нужна?
            </h2>

            <p class="mt-4 text-lg leading-8 text-slate-600">
              Можно начать не с выбора услуги, а с описания процесса:
              как он работает сейчас, где возникает ручная работа и что
              хотелось бы упростить.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            <Button
              href="/request"
              label="Получить разбор процесса"
              variant="primary"
              size="lg"
              goal="cta_process_review_click"
              goalLabel="services_page"
            />

            <Button
              href="/projects/konkursbstu"
              label="Смотреть кейс"
              variant="secondary"
              size="lg"
              goal="project_case_click"
              goalLabel="services_page"
            />
          </div>
        </div>
      </Card>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <SectionHeader
        eyebrow="Пример"
        title="Кейс konkursbstu.ru показывает подход к автоматизации"
        description="Это не просто сайт, а цифровая система с формами, заявками, файлами, базой данных, админ-панелью, статусами, документами и рассылками."
      />

      <div class="mt-8">
        <CTASection
          title="Хотите понять, как автоматизировать ваш процесс?"
          description="Опишите процесс простыми словами. Первый шаг — бесплатный разбор и определение MVP."
          primaryLabel="Получить бесплатный разбор процесса"
          primaryHref="/request"
          secondaryLabel="Смотреть кейс"
          secondaryHref="/projects/konkursbstu"
        />
      </div>
    </section>
  </main>
</Layout>