---
import Layout from '../../components/layout/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTASection from '../../components/ui/CTASection.astro';
import ServiceCard from '../../components/cards/ServiceCard.astro';
import { services } from '../../data/services';
---

<Layout
  title="Услуги по автоматизации процессов и разработке цифровых систем"
  description="Автоматизация бизнес-процессов, заявок, документов, Excel, рассылок, админ-панелей, личных кабинетов и workflow-систем."
>
  <main>
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <SectionHeader
        eyebrow="Услуги"
        title="Автоматизация процессов, заявок, документов и внутренних систем"
        description="Разрабатываю цифровые системы под конкретные процессы организаций: от формы заявки и базы данных до админ-панели, документов, рассылок и workflow."
      />

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {services.map((service) => (
          <ServiceCard service={service} />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10">
        <div class="grid gap-8 lg:grid-cols-[1fr_0.8fr] lg:items-center">
          <div>
            <p class="text-sm font-semibold text-blue-600">
              Не знаете, какая услуга нужна?
            </p>

            <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">
              Начните не с выбора услуги, а с разбора процесса
            </h2>

            <p class="mt-4 text-lg leading-8 text-slate-600">
              Опишите, как сейчас работают заявки, документы, файлы, статусы,
              сотрудники и рассылки. После этого можно понять, какой MVP нужен:
              форма, база данных, админ-панель, личный кабинет или workflow-система.
            </p>
          </div>

          <div class="rounded-2xl bg-slate-50 p-6">
            <p class="font-semibold text-slate-900">
              Пример реализованного кейса
            </p>

            <p class="mt-3 text-sm leading-6 text-slate-600">
              konkursbstu.ru — цифровая система для автоматизации конкурса,
              конференции, заявок, файлов, документов, приглашений и рассылок.
            </p>

            <a
              href="/projects/konkursbstu"
              class="mt-5 inline-flex font-semibold text-blue-600 hover:text-blue-700"
            >
              Смотреть кейс →
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title="Хотите понять, что можно автоматизировать в вашем процессе?"
        description="Опишите процесс простыми словами. Я помогу выделить повторяющиеся действия и предложить первый MVP цифровой системы."
        primaryLabel="Получить бесплатный разбор процесса"
        primaryHref="/request"
        secondaryLabel="Посмотреть кейс"
        secondaryHref="/projects/konkursbstu"
      />
    </section>
  </main>
</Layout>