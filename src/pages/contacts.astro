---
import Layout from '../components/layout/Layout.astro';
import { contacts } from '../data/contacts';
---

<Layout title="Контакты — обсудить автоматизацию процесса">
  <main class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-bold text-slate-900">
      Контакты
    </h1>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 text-slate-600">
      <p class="font-semibold text-slate-900">{contacts.name}</p>
      <p>{contacts.degree}</p>
      <p>{contacts.position}</p>
      <p>{contacts.organization}</p>

      <a
        href={contacts.phoneHref}
        data-goal="phone_click"
        data-goal-label="contacts_page"
        class="mt-4 inline-flex font-semibold text-blue-600 hover:text-blue-700"
      >
        {contacts.phone}
      </a>
    </div>
  </main>
</Layout>