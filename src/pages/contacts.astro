---
import Layout from '../components/layout/Layout.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import LeadForm from '../components/forms/LeadForm.astro';
import { contacts } from '../data/contacts';

const topics = [
  'автоматизация заявок',
  'цифровая система для мероприятия',
  'админ-панель',
  'личный кабинет',
  'генерация документов',
  'перенос Excel-процесса',
  'внутренний сервис',
  'workflow-система',
];
---

<Layout
  title="Контакты для обсуждения автоматизации процесса"
  description="Контакты для связи и обсуждения разработки цифровой системы автоматизации: заявки, документы, файлы, админ-панели и workflow."
>
  <main>
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold text-blue-600">
            Связь
          </p>

          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            Контакты
          </h1>

          <Card className="mt-8">
            <p class="text-xl font-bold text-slate-900">
              {contacts.name}
            </p>
            <p class="mt-3 text-slate-600">{contacts.degree}</p>
            <p class="text-slate-600">{contacts.position}</p>
            <p class="text-slate-600">{contacts.organization}</p>

            <a
              href={contacts.phoneHref}
              data-goal="phone_click"
              data-goal-label="contacts_page"
              class="mt-5 inline-flex text-lg font-semibold text-blue-600 hover:text-blue-700"
            >
              {contacts.phone}
            </a>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <Button
                href="/request"
                label="Получить бесплатный разбор процесса"
                variant="primary"
              />

              <Button
                href="/projects/konkursbstu"
                label="Смотреть кейс"
                variant="secondary"
              />
            </div>
          </Card>

          <Card className="mt-6">
            <h2 class="text-2xl font-bold text-slate-900">
              С какими вопросами можно обращаться
            </h2>

            <div class="mt-5 grid gap-3 md:grid-cols-2">
              {topics.map((topic) => (
                <div class="rounded-2xl bg-slate-50 p-4 text-sm font-semibold text-slate-700">
                  {topic}
                </div>
              ))}
            </div>
          </Card>
        </div>

        <LeadForm />
      </div>
    </section>
  </main>
</Layout>