---
import Layout from '../components/layout/Layout.astro';

import HomeHero from '../components/sections/HomeHero.astro';
import AutomationProcesses from '../components/sections/AutomationProcesses.astro';
import TargetAudiences from '../components/sections/TargetAudiences.astro';
import SolutionExamples from '../components/sections/SolutionExamples.astro';
import KonkursBstuPreview from '../components/sections/KonkursBstuPreview.astro';
import ServicesPreview from '../components/sections/ServicesPreview.astro';
import ProjectsPreview from '../components/sections/ProjectsPreview.astro';
import BenefitsBeforeAfter from '../components/sections/BenefitsBeforeAfter.astro';
import WorkProcess from '../components/sections/WorkProcess.astro';
import DemoBlock from '../components/sections/DemoBlock.astro';
import LeadMagnetBlock from '../components/sections/LeadMagnetBlock.astro';
import FAQSection from '../components/sections/FAQSection.astro';
import FinalCTA from '../components/sections/FinalCTA.astro';
---

<Layout
  title="Автоматизация процессов и цифровые системы для организаций"
  description="Разработка цифровых систем для автоматизации заявок, документов, файлов, статусов, админ-панелей, личных кабинетов, рассылок и workflow-решений."
>
  <main>
    <HomeHero />
    <AutomationProcesses />
    <TargetAudiences />
    <SolutionExamples />
    <KonkursBstuPreview />
    <ServicesPreview />
    <ProjectsPreview />
    <BenefitsBeforeAfter />
    <WorkProcess />
    <DemoBlock />
    <LeadMagnetBlock />
    <FAQSection />
    <FinalCTA />
  </main>
</Layout>