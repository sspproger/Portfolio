---
import Layout from '../components/layout/Layout.astro';
import { contacts } from '../data/contacts';
---

<Layout title="Заявка на автоматизацию процесса">
  <main class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-bold text-slate-900">
      Опишите процесс — я покажу, как его автоматизировать
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      Не нужно готовить техническое задание. Достаточно рассказать,
      как процесс работает сейчас и что в нём неудобно.
    </p>

    <div class="mt-8 rounded-2xl border border-slate-200 bg-white p-6">
      <p class="font-semibold text-slate-900">Быстрая связь</p>
      <a
        href={contacts.phoneHref}
        data-goal="phone_click"
        data-goal-label="request_page"
        class="mt-2 inline-flex font-semibold text-blue-600 hover:text-blue-700"
      >
        {contacts.phone}
      </a>
    </div>
  </main>
</Layout>