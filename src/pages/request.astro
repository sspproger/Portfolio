---
import Layout from '../components/layout/Layout.astro';
import BriefForm from '../components/forms/BriefForm.astro';
import Card from '../components/ui/Card.astro';
import CTASection from '../components/ui/CTASection.astro';

import { contacts } from '../data/contacts';
import { getSEO } from '../data/seo';
import { createBreadcrumbSchema } from '../data/schema';

const pageSeo = getSEO('/request')!;

const describeItems = [
  'где сейчас ведётся процесс',
  'какие данные собираются',
  'кто участвует',
  'какие документы формируются',
  'какие действия повторяются',
  'что хотелось бы упростить',
];

const afterSubmit = [
  'разбор процесса',
  'выделение MVP',
  'предварительная структура системы',
  'список возможных модулей',
  'ориентир по срокам',
];
---

<Layout
  title={pageSeo.title}
  description={pageSeo.description}
  canonicalPath="/request"
  schema={createBreadcrumbSchema([
    { name: 'Главная', url: '/' },
    { name: 'Заявка', url: '/request' },
  ])}
>
  <main id="main-content">
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
        <div>
          <p class="text-sm font-semibold text-blue-600">
            Заявка
          </p>

          <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            Заявка на автоматизацию процесса
          </h1>

          <p class="mt-5 text-lg leading-8 text-slate-600">
            Опишите процесс, который хотите автоматизировать. Не нужно готовить
            техническое задание — достаточно рассказать, как всё работает сейчас.
          </p>

          <Card className="mt-8">
            <h2 class="text-2xl font-bold text-slate-900">
              Что можно описать
            </h2>

            <div class="mt-5 grid gap-3">
              {describeItems.map((item) => (
                <div class="rounded-2xl bg-slate-50 p-4 text-sm font-medium text-slate-700">
                  {item}
                </div>
              ))}
            </div>
          </Card>

          <div class="mt-8 rounded-2xl border border-blue-100 bg-blue-50 p-5 text-sm leading-6 text-slate-700">
            Альтернативный контакт:
            <a
              href={contacts.phoneHref}
              data-goal="phone_click"
              data-goal-label="request_page"
              class="font-semibold text-blue-600 hover:text-blue-700"
            >
              {contacts.phone}
            </a>
          </div>
        </div>

        <BriefForm />
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <Card>
        <h2 class="text-3xl font-bold tracking-tight text-slate-900">
          Что будет после отправки
        </h2>

        <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
          {afterSubmit.map((item, index) => (
            <div class="rounded-2xl bg-slate-50 p-4">
              <div class="flex h-9 w-9 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                {index + 1}
              </div>

              <p class="mt-4 text-sm font-semibold text-slate-800">
                {item}
              </p>
            </div>
          ))}
        </div>
      </Card>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title="Можно начать с простого описания процесса"
        description="Даже если пока нет технического задания, можно разобрать текущую логику и определить первый MVP."
        primaryLabel="Отправить заявку"
        primaryHref="/request"
        secondaryLabel="Смотреть кейс"
        secondaryHref="/projects/konkursbstu"
      />
    </section>

    <script is:inline>
      window.__pendingAnalyticsGoals = window.__pendingAnalyticsGoals || [];
      window.siteAnalytics?.reachGoal
        ? window.siteAnalytics.reachGoal('request_page_view', {
            page: window.location.pathname,
          })
        : window.__pendingAnalyticsGoals.push({
            goal: 'request_page_view',
            params: { page: window.location.pathname },
          });
    </script>
  </main>
</Layout>