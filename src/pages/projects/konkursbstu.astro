---
import Layout from '../../components/layout/Layout.astro';
import CTASection from '../../components/ui/CTASection.astro';

import CaseHero from '../../components/case/CaseHero.astro';
import CaseSummary from '../../components/case/CaseSummary.astro';
import CaseProblem from '../../components/case/CaseProblem.astro';
import CaseModules from '../../components/case/CaseModules.astro';
import CaseScreenshots from '../../components/case/CaseScreenshots.astro';
import CaseArchitecture from '../../components/case/CaseArchitecture.astro';
import CaseResult from '../../components/case/CaseResult.astro';
import CaseApplications from '../../components/case/CaseApplications.astro';

import { getProjectBySlug } from '../../data/projects';
import { getSEO } from '../../data/seo';
import {
  createBreadcrumbSchema,
  createCaseStudySchema,
} from '../../data/schema';

const project = getProjectBySlug('konkursbstu');
const pageSeo = getSEO('/projects/konkursbstu')!;

if (!project) {
  throw new Error('Проект konkursbstu не найден в src/data/projects.ts');
}
---

<Layout
  title={pageSeo.title}
  description={pageSeo.description}
  canonicalPath="/projects/konkursbstu"
  schema={[
    createCaseStudySchema(),
    createBreadcrumbSchema([
      { name: 'Главная', url: '/' },
      { name: 'Проекты', url: '/projects' },
      { name: 'Кейс konkursbstu.ru', url: '/projects/konkursbstu' },
    ]),
  ]}
>
  <main id="main-content">
    <CaseHero project={project} />
    <CaseSummary project={project} />
    <CaseProblem />
    <CaseModules project={project} />
    <CaseScreenshots />
    <CaseArchitecture />
    <CaseResult />
    <CaseApplications />

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title="Хотите похожую систему под свой процесс?"
        description="Опишите, какие заявки, данные, документы, файлы, статусы или уведомления нужно автоматизировать. Первый шаг — бесплатный разбор процесса."
        primaryLabel="Хочу похожую систему"
        primaryHref="/request"
        secondaryLabel="Смотреть услуги"
        secondaryHref="/services"
      />
    </section>

    <script is:inline>
      window.__pendingAnalyticsGoals = window.__pendingAnalyticsGoals || [];
      window.siteAnalytics?.reachGoal
        ? window.siteAnalytics.reachGoal('case_view', {
            page: window.location.pathname,
          })
        : window.__pendingAnalyticsGoals.push({
            goal: 'case_view',
            params: { page: window.location.pathname },
          });
    </script>
  </main>
</Layout>