---
import Layout from '../../components/layout/Layout.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';
import CTASection from '../../components/ui/CTASection.astro';

import { projects } from '../../data/projects';
import { getSEO } from '../../data/seo';
import { createBreadcrumbSchema } from '../../data/schema';

const pageSeo = getSEO('/projects')!;
---

<Layout
  title={pageSeo.title}
  description={pageSeo.description}
  canonicalPath="/projects"
  schema={createBreadcrumbSchema([
    { name: 'Главная', url: '/' },
    { name: 'Проекты', url: '/projects' },
  ])}
>
  <main id="main-content">
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <p class="text-sm font-semibold text-blue-600">
        Проекты
      </p>

      <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
        Реализованные проекты
      </h1>

      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
        Примеры цифровых систем для автоматизации заявок, файлов, документов,
        статусов, админ-панелей, рассылок и работы организаторов.
      </p>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="grid gap-6">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title="Хотите похожую систему под свой процесс?"
        description="Кейс показывает подход к автоматизации, который можно применить и к другим задачам: заявкам, документам, файлам, статусам и уведомлениям."
        primaryLabel="Получить разбор процесса"
        primaryHref="/request"
        secondaryLabel="Смотреть услуги"
        secondaryHref="/services"
      />
    </section>
  </main>
</Layout>