---
import Layout from '../../components/layout/Layout.astro';
---

<Layout title="Реализованные проекты автоматизации">
  <main class="mx-auto max-w-6xl px-4 py-16">
    <h1 class="text-4xl font-bold text-slate-900">
      Реализованные проекты
    </h1>

    <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">
      Здесь будет представлен кейс konkursbstu.ru как цифровая система
      автоматизации конкурсов, конференции, приглашений и рассылок.
    </p>

    <a
      href="/projects/konkursbstu"
      class="mt-8 inline-flex rounded-xl bg-blue-600 px-5 py-3 font-semibold text-white hover:bg-blue-700"
    >
      Смотреть кейс
    </a>
  </main>
</Layout>