---
import Layout from '../../components/layout/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CTASection from '../../components/ui/CTASection.astro';
import ProjectCard from '../../components/cards/ProjectCard.astro';
import { projects } from '../../data/projects';
---

<Layout
  title="Реализованные проекты автоматизации"
  description="Кейсы разработки цифровых систем для автоматизации заявок, документов, файлов, админ-панелей и рассылок."
>
  <main>
    <section class="mx-auto max-w-6xl px-4 py-16 md:py-20">
      <SectionHeader
        eyebrow="Проекты"
        title="Реализованные цифровые системы"
        description="Здесь показаны проекты, где автоматизируются реальные процессы: заявки, данные, файлы, документы, админ-панели, статусы и рассылки. Это не ограничение по тематике, а доказательство подхода."
      />

      <div class="mt-10 grid gap-6">
        {projects.map((project) => (
          <ProjectCard project={project} />
        ))}
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-16">
      <div class="rounded-3xl border border-slate-200 bg-white p-8 md:p-10">
        <p class="text-sm font-semibold text-blue-600">
          Важно
        </p>

        <h2 class="mt-3 text-3xl font-bold tracking-tight text-slate-900">
          Кейс konkursbstu.ru — это один пример, а не единственное направление
        </h2>

        <p class="mt-4 max-w-4xl text-lg leading-8 text-slate-600">
          Такой же подход можно применить к другим процессам: приёму заявок,
          обработке документов, внутренним сервисам, административным панелям,
          личным кабинетам, рассылкам, Excel-процессам и workflow-системам.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-6xl px-4 pb-20">
      <CTASection
        title="Хотите похожую систему под свой процесс?"
        description="Опишите задачу: какие заявки, данные, документы, файлы, статусы или уведомления нужно автоматизировать."
        primaryLabel="Хочу похожую систему"
        primaryHref="/request"
        secondaryLabel="Посмотреть услуги"
        secondaryHref="/services"
      />
    </section>
  </main>
</Layout>